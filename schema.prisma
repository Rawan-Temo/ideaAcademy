// ==================================================
// NRLS - Rojava Center for Strategic Studies
// Prisma Schema — MariaDB (single database)
// ==================================================

generator client {
  provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ==================================================
// ENUMS
// ==================================================

enum LanguageEnum {
  ar
  ku
  en
}

enum ContentType {
  text
  infographic
  video
  documentary
  report
  survey
  publication
  event
}

enum PublicationType {
  magazine
  book
}

enum EventType {
  dialogue_session
  forum
  meeting
  center_news
}

enum MediaFileType {
  image
  video
  pdf
  audio
}

// ==================================================
// GENERAL
// ==================================================

model Language {
  id        BigInt    @id @default(autoincrement())
  code      LanguageEnum  @unique
  name      String    @db.VarChar(50)

  createdAt DateTime? @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("languages")
}

model Category {
  id          BigInt    @id @default(autoincrement())
  slug        String    @unique @db.VarChar(100)
  nameAr      String    @map("name_ar") @db.VarChar(100)
  nameKu      String?   @map("name_ku") @db.VarChar(100)
  nameEn      String?   @map("name_en") @db.VarChar(100)
  description String?   @db.Text
  sortOrder   Int       @default(0) @map("sort_order")

  posts       Post[]

  createdAt   DateTime? @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([slug], map: "idx_category_slug")
  @@map("categories")
}

// ==================================================
// AUTHORS
// ==================================================

model Author {
  id           BigInt    @id @default(autoincrement())
  fullName     String    @map("full_name") @db.VarChar(150)
  slug         String    @unique @db.VarChar(150)
  bio          String?   @db.Text
  profileImage String?   @map("profile_image") @db.VarChar(255)
  email        String?   @db.VarChar(100)

  posts        Post[]

  createdAt    DateTime? @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@index([slug], map: "idx_author_slug")
  @@map("authors")
}

// ==================================================
// POSTS
// ==================================================

model Post {
  id               BigInt      @id @default(autoincrement())

  // Translation self-reference
  originalPostId   BigInt?     @map("original_post_id")
  originalPost     Post?       @relation("PostTranslations", fields: [originalPostId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  translations     Post[]      @relation("PostTranslations")

  authorId         BigInt?     @map("author_id")
  author           Author?     @relation(fields: [authorId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  categoryId       BigInt      @map("category_id")
  category         Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  contentType      ContentType @default(text) @map("content_type")
  language         LanguageEnum    @default(ar)

  title            String      @db.VarChar(500)
  slug             String      @db.VarChar(500)
  excerpt          String?     @db.Text
  content          String?     @db.LongText

  metaTitle        String?     @map("meta_title") @db.VarChar(255)
  metaDescription  String?     @map("meta_description") @db.Text
  featuredImage    String?     @map("featured_image") @db.VarChar(255)

  viewCount        Int         @default(0) @map("view_count")
  isPublished      Boolean     @default(false) @map("is_published")
  publishedAt      DateTime?   @map("published_at")

  createdAt        DateTime?   @map("created_at")
  updatedAt        DateTime?   @updatedAt @map("updated_at")
  deletedAt        DateTime?   @map("deleted_at")

  // Relations
  tags             PostTag[]
  comments         Comment[]
  files            File[]
  publication      Publication?
  event            Event?
  survey           Survey?

  @@unique([slug, language], map: "idx_post_slug_lang")
  @@index([authorId])
  @@index([categoryId])
  @@index([language])
  @@index([contentType], map: "idx_post_content_type")
  @@index([isPublished])
  @@index([publishedAt])
  @@index([originalPostId], map: "idx_post_original_id")
  @@map("posts")
}

// ==================================================
// TAGS
// ==================================================

model Tag {
  id       BigInt    @id @default(autoincrement())
  nameAr   String    @unique @map("name_ar") @db.VarChar(100)
  nameKu   String?   @map("name_ku") @db.VarChar(100)
  nameEn   String?   @map("name_en") @db.VarChar(100)
  slug     String    @unique @db.VarChar(100)

  posts    PostTag[]

  createdAt DateTime? @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([slug], map: "idx_tag_slug")
  @@map("tags")
}

model PostTag {
  postId  BigInt  @map("post_id")
  tagId   BigInt  @map("tag_id")

  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([postId, tagId])
  @@index([postId])
  @@index([tagId])
  @@map("post_tags")
}

// ==================================================
// COMMENTS
// ==================================================

model Comment {
  id         BigInt    @id @default(autoincrement())
  postId     BigInt    @map("post_id")
  post       Post      @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  name       String    @db.VarChar(100)
  email      String?   @db.VarChar(150)
  comment    String    @db.Text
  isApproved Boolean   @default(false) @map("is_approved")

  createdAt  DateTime? @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([postId], map: "idx_comment_post_id")
  @@index([isApproved])
  @@map("comments")
}

// ==================================================
// MEDIA
// ==================================================

model File {
  id         BigInt        @id @default(autoincrement())
  postId     BigInt?       @map("post_id")
  post       Post?         @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  fileType   MediaFileType @map("file_type")
  src        String        @unique @db.VarChar(500)
  altText    String?       @map("alt_text") @db.VarChar(255)
  caption    String?       @db.Text
  mimeType   String?       @map("mime_type") @db.VarChar(100)
  fileSizeKb Int?          @map("file_size_kb")

  createdAt  DateTime?     @map("created_at")
  updatedAt  DateTime?     @updatedAt @map("updated_at")
  deletedAt  DateTime?     @map("deleted_at")

  @@index([postId])
  @@index([fileType])
  @@map("files")
}

// ==================================================
// PUBLICATIONS
// ==================================================

model Publication {
  id              BigInt          @id @default(autoincrement())
  postId          BigInt          @unique @map("post_id")
  post            Post            @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  publicationType PublicationType @map("publication_type")
  issueNumber     String?         @map("issue_number") @db.VarChar(50)
  volume          String?         @db.VarChar(50)
  isbn            String?         @db.VarChar(30)
  downloadUrl     String?         @map("download_url") @db.VarChar(500)
  coverImage      String?         @map("cover_image") @db.VarChar(500)
  pageCount       Int?            @map("page_count")
  publishYear     Int?            @map("publish_year")

  createdAt       DateTime?       @map("created_at")
  updatedAt       DateTime?       @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  @@index([publicationType])
  @@map("publications")
}

// ==================================================
// EVENTS
// ==================================================

model Event {
  id             BigInt    @id @default(autoincrement())
  postId         BigInt    @unique @map("post_id")
  post           Post      @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  eventType      EventType @map("event_type")
  eventDate      DateTime? @map("event_date")
  location       String?   @db.VarChar(255)
  attendeesCount Int?      @map("attendees_count")

  createdAt      DateTime? @map("created_at")
  updatedAt      DateTime? @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  @@index([eventType])
  @@index([eventDate])
  @@map("events")
}

// ==================================================
// SURVEYS
// ==================================================

model Survey {
  id        BigInt         @id @default(autoincrement())
  postId    BigInt         @unique @map("post_id")
  post      Post           @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  question  String         @db.Text
  isActive  Boolean        @default(true) @map("is_active")
  closesAt  DateTime?      @map("closes_at")

  options   SurveyOption[]

  createdAt DateTime?      @map("created_at")
  updatedAt DateTime?      @updatedAt @map("updated_at")
  deletedAt DateTime?      @map("deleted_at")

  @@map("surveys")
}

model SurveyOption {
  id         BigInt    @id @default(autoincrement())
  surveyId   BigInt    @map("survey_id")
  survey     Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  optionText String    @map("option_text") @db.VarChar(500)
  voteCount  Int       @default(0) @map("vote_count")

  createdAt  DateTime? @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  @@index([surveyId])
  @@map("survey_options")
}

// ==================================================
// AUTH
// ==================================================

model User {
  id        BigInt    @id @default(autoincrement())

  username  String    @unique @db.VarChar(100)
  fullName  String    @map("full_name") @db.VarChar(150)
  password  String    @db.VarChar(255)
  email     String?   @unique @db.VarChar(100)
  role      String    @default("user") @db.VarChar(30)
  active    Boolean   @default(true)

  createdAt DateTime? @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([username], map: "idx_user_username")
  @@index([email], map: "idx_user_email")
  @@map("users")
}